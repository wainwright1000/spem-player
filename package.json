{
  "name": "spem-player",
  "private": true,
  "version": "2.4.0",
  "description": "Helping singers learn Thomas Tallis Spem in alium",
  "main": "src/index.js",
  "type": "module",
  "dependencies": {
    "ohm-js": "^17.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@ohm-js/cli": "^2.0.1",
    "@playwright/test": "^1.59.1",
    "@types/jest": "^30.0.0",
    "@types/jsdom": "^28.0.2",
    "@vitest/coverage-v8": "^4.1.6",
    "@vitest/ui": "^4.1.5",
    "autoprefixer": "^10.4.21",
    "canvas": "^3.2.0",
    "clean-css-cli": "^5.6.3",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.4",
    "prettier": "^3.8.3",
    "sass-embedded": "^1.93.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vite-plugin-commonjs": "^0.10.4",
    "vitest": "^4.1.5",
    "vitest-fetch-mock": "^0.4.5"
  },
  "scripts": {
    "dev": "vite --host",
    "build": "npm run format:check && npm run lint && npm run build:ohm && vite build",
    "build:scores": "node build/buildScores.mjs",
    "build:ohm": "npx ohm generateBundles --withTypes src/ohmjs/ly-grammar.ohm",
    "preview": "vite preview",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "test:ui": "vitest --ui",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "ci": "npm run build && vitest --run && npm run test:e2e",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx,js,jsx,json,scss,css,html,md}": [
      "prettier --write"
    ]
  },
  "author": "Mark Wainwright",
  "license": "MIT"
}
