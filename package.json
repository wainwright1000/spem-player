{
  "name": "spem-player",
  "private": true,
  "version": "2.2.0",
  "description": "Helping singers learn Thomas Tallis Spem in alium",
  "main": "src/index.js",
  "type": "module",
  "dependencies": {
    "ohm-js": "^17.2.1"
  },
  "devDependencies": {
    "@ohm-js/cli": "^2.0.1",
    "@types/jest": "^30.0.0",
    "@types/jsdom": "^28.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "autoprefixer": "^10.4.21",
    "canvas": "^3.2.0",
    "clean-css-cli": "^5.6.3",
    "eslint": "^10.2.1",
    "jsdom": "^29.1.1",
    "sass-embedded": "^1.93.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vite-plugin-commonjs": "^0.10.4",
    "vitest": "^4.1.5",
    "vitest-fetch-mock": "^0.4.5"
  },
  "scripts": {
    "dev": "vite --host",
    "build": "npm run build:ohm && vite build",
    "build:scores": "bash ./buildAllScores.sh",
    "build:ohm": "npx ohm generateBundles --withTypes src/ohmjs/ly-grammar.ohm",
    "preview": "vite preview",
    "test:ui": "vitest --ui",
    "test": "vitest",
    "coverage": "vitest run --coverage"
  },
  "author": "Mark Wainwright",
  "license": "MIT"
}
